rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - user_id: string (required)
    //   - full_name: string (required)
    //   - profile_photo_url: string (optional)
    //   - skill_level: string (optional, enum: Beginner, Intermediate, Advanced)
    //   - bio: string (optional)
    //   - friend_count: number (optional)
    //
    // Collection: friendships
    // Document ID: friendshipId (e.g., uid1_uid2)
    // Fields:
    //   - users: list of strings (required, size 2)
    //   - status: string (required, enum: pending, accepted)
    //   - requester_id: string (required)
    //   - created_at: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['user_id', 'full_name']) &&
             data.user_id is string &&
             data.full_name is string &&
             data.full_name.size() > 0 && data.full_name.size() < 100 &&
             (!('bio' in data) || (data.bio is string && data.bio.size() < 500)) &&
             (!('skill_level' in data) || data.skill_level in ['Beginner', 'Intermediate', 'Advanced']);
    }

    function isValidFriendship(data) {
      return data.keys().hasAll(['users', 'status', 'requester_id']) &&
             data.users is list && data.users.size() == 2 &&
             data.status in ['pending', 'accepted'] &&
             data.requester_id is string &&
             data.requester_id in data.users;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /friendships/{friendshipId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.users);
      allow create: if isAuthenticated() && 
                    (request.auth.uid in request.resource.data.users) && 
                    isValidFriendship(request.resource.data) &&
                    request.resource.data.status == 'pending' &&
                    request.resource.data.requester_id == request.auth.uid;
      allow update: if isAuthenticated() && 
                    (request.auth.uid in resource.data.users) &&
                    isValidFriendship(request.resource.data) &&
                    // Only non-requester can accept
                    (resource.data.status == 'pending' && 
                     request.resource.data.status == 'accepted' && 
                     request.auth.uid != resource.data.requester_id) ||
                    // Or requester can cancel (delete) or both can unfriend (delete)
                    // But for update, we only allow status change to accepted
                    (resource.data.status == 'accepted' && request.resource.data.status == 'accepted');
      allow delete: if isAuthenticated() && (request.auth.uid in resource.data.users);
    }
  }
}
